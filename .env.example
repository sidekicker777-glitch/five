# Optional frontend defaults
NEXT_PUBLIC_DEFAULT_TEAM_ID=YOUR_TEAM_ID
NEXT_PUBLIC_DEFAULT_BOT_ID=YOUR_BOT_ID

# Use ONE of the auth options below.
# 1) Trusted server-side API key (simple for private bots on your own backend)
DOCSBOT_API_KEY=YOUR_DOCSBOT_API_KEY

# 2) Or recommended private-bot signing key for JWT auth
DOCSBOT_SIGNATURE_KEY=YOUR_DOCSBOT_SIGNATURE_KEY

# Optional server-side fallbacks if you do not want to pass IDs from the client
DOCSBOT_TEAM_ID=YOUR_TEAM_ID
DOCSBOT_BOT_ID=YOUR_BOT_ID
